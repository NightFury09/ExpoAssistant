<?xml version="1.0"?>
<!--
  rover.urdf — Minimal robot description for expo_rover
  Defines: base_footprint, base_link, laser_frame, and wheel links

  Dimensions:
    - Length: 0.43m
    - Width: 0.44m
    - Height: 0.23m
    - RPLIDAR mounted center, pointing forward, exactly 0.23m off ground
-->
<robot name="expo_rover">

  <!-- ====================================================================
       Base Footprint — Ground level center, NO inertia (fixes KDL warning)
       ==================================================================== -->
  <link name="base_footprint"/>

  <!-- ====================================================================
       Base Link — geometric centre of the chassis
       ==================================================================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <!-- Representing the rover chassis as a box 0.43 L x 0.44 W x 0.23 H -->
        <box size="0.43 0.44 0.23"/>
      </geometry>
      <!-- Visual origin: the box center is half its height above base_footprint -->
      <origin xyz="0 0 0.115" rpy="0 0 0"/>
      <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.43 0.44 0.23"/>
      </geometry>
      <origin xyz="0 0 0.115" rpy="0 0 0"/>
    </collision>
    <inertial>
      <!-- Inertia is attached to base_link, not base_footprint -->
      <origin xyz="0 0 0.115" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0"
               iyy="0.1" iyz="0"
               izz="0.2"/>
    </inertial>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ====================================================================
       Laser Frame — RPLIDAR mounting point
       ==================================================================== -->
  <link name="laser_frame">
    <visual>
      <geometry>
        <!-- Small cylinder to represent the LiDAR puck -->
        <cylinder length="0.04" radius="0.04"/>
      </geometry>
      <!-- Move visual up slightly so it sits on the frame origin -->
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0.0 0.4 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <!-- Attach to base_footprint so Z is absolute height from ground -->
    <parent link="base_footprint"/>
    <child link="laser_frame"/>
    <!-- Center mounted, facing forward, exactly 23cm above ground -->
    <origin xyz="0.0 0.0 0.23" rpy="0 0 0"/>
  </joint>

  <!-- ====================================================================
       Left Wheel
       ==================================================================== -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.05" radius="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_footprint"/>
    <child link="left_wheel"/>
    <origin xyz="0.0 0.22 0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ====================================================================
       Right Wheel
       ==================================================================== -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.05" radius="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_footprint"/>
    <child link="right_wheel"/>
    <origin xyz="0.0 -0.22 0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

</robot>
